# At least one LLM key is required. Both can be set for automatic fallback.

# Groq (recommended — most generous free tier, 60 req/min)
# Get free key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (fallback — stricter free limits)
# Get free key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

PORT=3000
NODE_ENV=development

# MongoDB Atlas (free 512MB tier)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/resume-ats?retryWrites=true&w=majority

# JWT secret for session tokens (use a random 32+ char string)
JWT_SECRET=replace_with_a_random_secret

# Google OAuth Client ID (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
